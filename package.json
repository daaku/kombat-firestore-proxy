    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@daaku/firebase-auth": "^2.7.0",
    "@daaku/firebase-rest-api": "^2.4.0",
    "@daaku/kombat": "^2.17.0",
    "@daaku/kombat-firestore": "^2.8.0",
    "@daaku/kombat-indexed-db": "^3.8.0"
